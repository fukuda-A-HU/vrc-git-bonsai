<UXML xmlns="UnityEngine.UIElements">
    <VisualElement name="notification-block" class="col mt-2 mb-2 w-100 flex-shrink-0">
        <Label name="main-text" class="text-lg mt-2 p-2 white-space-normal flex-grow-1" />
        <Label name="details-text" class="mt-2 p-2 white-space-normal flex-grow-1" />
        <VisualElement name="action-buttons" class="row mt-3">
            <Button class="pl-4 pr-4 pt-2 pb-2 text-bold mr-2 flex-grow-1" name="learn-more-button" />
            <Button class="pl-4 pr-4 pt-2 pb-2 text-bold flex-grow-1" name="disagree-button" />
        </VisualElement>
    </VisualElement>
</UXML>